{
	"appId": "com.plyship.app",
	"appName": "PLYSHIP",
	"webDir": "www",
	"server": {
		"url": "https://plyship.com",
		"cleartext": false
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"launchShowDuration": 2000,
			"backgroundColor": "#0A0A0F",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#FFFFFF",
			"overlaysWebView": false
		}
	},
	"ios": {
		"contentInset": "never",
		"backgroundColor": "#FFFFFF",
		"allowsLinkPreview": false,
		"preferredContentMode": "mobile"
	},
	"packageClassList": [
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
